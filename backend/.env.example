# Postgres connection string. On the shared server, point this at the existing
# instance — KidGo only creates kidgo_*-prefixed tables.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# HTTP port the API listens on.
PORT=8080

# Optional LLM provider for NLU (OpenAI-compatible chat/completions).
# Without these, NLU falls back to the deterministic rule parser.
KIDGO_LLM_BASE_URL=
KIDGO_LLM_API_KEY=
KIDGO_LLM_MODEL=glm-5.1

# Optional vision provider — lets the bot read images (flyers/photos) sent on
# WhatsApp. OpenAI-compatible chat endpoint that accepts image_url content.
# Each can be a different provider/key from the chat model. Unset = images
# get a "please type it" reply.
KIDGO_VISION_BASE_URL=
KIDGO_VISION_API_KEY=
KIDGO_VISION_MODEL=

# Optional audio provider — lets the bot understand voice notes. OpenAI-compatible
# chat endpoint that accepts input_audio content. Unset = voice notes get a
# "please type it" reply.
KIDGO_AUDIO_BASE_URL=
KIDGO_AUDIO_API_KEY=
KIDGO_AUDIO_MODEL=

# HMAC key signing the 1-hour "manage link" tokens (>=16 chars). REQUIRED in
# production — if unset, an ephemeral key is generated and all outstanding
# manage links break on every restart. Generate one with e.g. `openssl rand -hex 32`.
KIDGO_LINK_SECRET=
