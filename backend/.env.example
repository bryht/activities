# Postgres connection string. On the shared server, point this at the existing
# instance — KidGo only creates kidgo_*-prefixed tables.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# HTTP port the API listens on.
PORT=8080

# Optional LLM provider for NLU (OpenAI-compatible chat/completions).
# Without these, NLU falls back to the deterministic rule parser.
KIDGO_LLM_BASE_URL=
KIDGO_LLM_API_KEY=
KIDGO_LLM_MODEL=glm-5.1
