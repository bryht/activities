# KidGo bot — configure one or more platforms. An adapter is enabled only when
# its variables are set, so Telegram-only still works with just the token.

# --- Telegram (BotFather) ---
TELEGRAM_BOT_TOKEN=

# --- WhatsApp (Meta Cloud API) ---
# From the Meta app: the WhatsApp Business phone-number id, a (system-user)
# access token, and a verify token you invent and paste into the webhook config.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# --- Signal (signal-cli native daemon, JSON-RPC over TCP) ---
# host:port of `signal-cli -a +<number> daemon --tcp 127.0.0.1:7583`, and the
# registered number the daemon runs as.
SIGNAL_JSONRPC=127.0.0.1:7583
SIGNAL_NUMBER=
# Where signal-cli saves received attachments (read to support photos/voice on
# Signal). Defaults to ~/.local/share/signal-cli/attachments for the daemon user.
SIGNAL_ATTACHMENTS_DIR=

# Port for the local HTTP server (WhatsApp webhook + /health).
PORT=8099

# Base URL of the KidGo API.
# Local dev: http://localhost:8080
# On the server, talk to the API directly (skip nginx/TLS): http://127.0.0.1:8090
KIDGO_API_BASE=http://localhost:8080

# Public website base, used to build the activity "manage" deep links.
KIDGO_WEB_BASE=https://kidgo.bryht.net

# pino log level (silent|info|debug). Default silent.
LOG_LEVEL=silent
