# Base URL of the KidGo API. Set at build time (Vite inlines VITE_* vars).
VITE_API_BASE=http://localhost:8080

# WhatsApp bot number (E.164, no "+") used by the "I want to come" deep links.
VITE_BOT_NUMBER=31600000000

# WhatsApp contact QR link, rendered as a scannable QR on the About page.
VITE_BOT_QR_URL=https://wa.me/qr/FVDNWYDE2CR2N1
