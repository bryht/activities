# Base URL of the KidGo API. Set at build time (Vite inlines VITE_* vars).
VITE_API_BASE=http://localhost:8080

# Telegram bot username (no "@") used by the "I want to come" deep links.
VITE_BOT_USERNAME=kidgo_bot

# Telegram bot link, rendered as a scannable QR on the About page.
VITE_BOT_LINK=https://t.me/kidgo_bot
